{
  "manifest_version": 3,
  "name": "FPT FAP Dashboard",
  "version": "6.2.0",
  "description": "Xem GPA, điểm danh, lịch học, lịch thi, thống kê, tính toán GPA, export calendar và nhiều tính năng nâng cao",
  "icons": {
    "128": "assets/icons/icon128.png"
  },
  "action": {
    "default_popup": "pages/popup.html",
    "default_icon": {
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "permissions": [
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://fap.fpt.edu.vn/*",
    "https://feid.fpt.edu.vn/*",
    "https://lms-hcm.fpt.edu.vn/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://fap.fpt.edu.vn/FrontOffice/MoveSubject.aspx*"
      ],
      "js": [
        "scripts/modules/utils.js",
        "scripts/modules/ui.js",
        "scripts/fap-moveclass.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/Grade/StudentTranscript.aspx*"
      ],
      "js": [
        "scripts/fap-transcript.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/Student.aspx*"
      ],
      "js": [
        "scripts/fap-schedule.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/Report/ScheduleOfWeek.aspx*"
      ],
      "js": [
        "scripts/fap-schedule-week.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/Exam/ScheduleExams.aspx*"
      ],
      "js": [
        "scripts/fap-exam.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/FrontOffice/SubjectFees.aspx*"
      ],
      "js": [
        "scripts/fap-subjectfees.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/CmsFAP/News.aspx*",
        "https://fap.fpt.edu.vn/CmsFAP/PlusNews.aspx*",
        "https://fap.fpt.edu.vn/CmsFAP/NewsDetail.aspx*"
      ],
      "js": [
        "scripts/fap-news-gate.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/",
        "https://fap.fpt.edu.vn/Default.aspx*"
      ],
      "js": [
        "scripts/fap-login.js",
        "scripts/onboarding.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://feid.fpt.edu.vn/Account/Login*"
      ],
      "js": [
        "scripts/feid-login.js",
        "scripts/onboarding.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://lms-hcm.fpt.edu.vn/login/index.php*"
      ],
      "js": [
        "scripts/lms-login.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://fap.fpt.edu.vn/Thongbao.aspx*"
      ],
      "js": [
        "scripts/fap-thongbao-skip.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "pages/report.html",
        "pages/dashboard.html",
        "scripts/report.js",
        "styles/report.css",
        "styles/dashboard.css",
        "styles/timer-icons.css",
        "styles/fap-transcript.css",
        "styles/fap-schedule.css",
        "styles/fap-schedule-week.css",
        "styles/fap-exam.css",
        "styles/fap-subjectfees.css",
        "styles/fap-news.css",
        "styles/fap-login.css",
        "styles/fap-moveclass.css",
        "styles/components.css",
        "styles/feid-login.css",
        "assets/icons/icon128.png",
        "assets/vendor/chart.min.js",
        "scripts/auto-calendar.js",
        "wallpaper/wallpaper1.jpg",
        "wallpaper/sample.jpg"
      ],
      "matches": [
        "https://fap.fpt.edu.vn/*",
        "https://feid.fpt.edu.vn/*"
      ]
    }
  ]
}